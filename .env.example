# Application
NODE_ENV=production
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=https://shop.example.kg
TRUST_PROXY=true
LOG_LEVEL=info

# PostgreSQL used by the app container
DATABASE_URL=postgresql://ailuu:CHANGE_ME_DB_PASSWORD@postgres:5432/ailuu
DATABASE_SSL=false
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_CONNECTION_TIMEOUT_MS=10000

# PostgreSQL container initialization
POSTGRES_DB=ailuu
POSTGRES_USER=ailuu
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
ORDER_NOTIFICATION_CHAT_ID=
# webhook is recommended behind a public HTTPS domain; use polling before the domain is ready
TELEGRAM_MODE=disabled
TELEGRAM_WEBHOOK_PATH=/internal/telegram/webhook
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_CHARS

# Files and limits
UPLOADS_DIR=/app/data/uploads
MAX_IMAGE_BYTES=8000000
ORDER_RATE_LIMIT_MAX=8
ORDER_RATE_LIMIT_WINDOW=15 minutes

# Safe automatic startup for a single deployment pipeline
RUN_MIGRATIONS_ON_START=true
RUN_SEED_ON_START=true
